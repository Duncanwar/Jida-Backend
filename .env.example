# --- Local development ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jida?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ACCESS_EXPIRES_MIN="15"
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
UPLOAD_DIR="./uploads"

# Optional SMTP (TLS). Leave empty to log emails to console in development.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="JIDA <noreply@auca.rw>"

# --- Render (set in Dashboard or via render.yaml) ---
# Render injects PORT automatically — do not hardcode it in production.
# PORT=<injected by Render>
# NODE_ENV=production
# DATABASE_URL=<from linked Postgres service>
# JWT_SECRET=<auto-generated by render.yaml, or set manually>
# CORS_ORIGIN=https://your-frontend.onrender.com
# UPLOAD_DIR=/var/data/uploads
# SMTP_*=<configure for production email>
